\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Human baseline results from the Vayun-Sharayu benchmark-enabled game. Task success rates are similar across players (77.5\% vs. 75.6\%), but benchmark scores differ due to high variance in win rate. As the number of games increases, win rates are expected to stabilize (e.g., ~60-40 rather than 100-0), narrowing this gap.}}{3}{figure.caption.5}\protected@file@percent }
\newlabel{fig:human-baseline}{{1}{3}{Human baseline results from the Vayun-Sharayu benchmark-enabled game. Task success rates are similar across players (77.5\% vs. 75.6\%), but benchmark scores differ due to high variance in win rate. As the number of games increases, win rates are expected to stabilize (e.g., ~60-40 rather than 100-0), narrowing this gap}{figure.caption.5}{}}
