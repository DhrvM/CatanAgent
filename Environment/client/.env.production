# Production environment for the Vercel deployment.
# Vite reads this file automatically during `vite build`.
# The value can still be overridden in the Vercel dashboard's
# "Environment Variables" → "Production" settings.
#
# Note: App.jsx also falls back to the hosted URL at runtime whenever the page
# is served from a non-localhost origin, so the deploy self-heals even if this
# file is missing in some build context.
VITE_SERVER_URL=https://catanagent.onrender.com
