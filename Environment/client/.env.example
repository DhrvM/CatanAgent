# Copy this file to `.env.local` (for `npm run dev`) or `.env.production` (for `npm run build`)
# and set the URL of the Catan game server.
#
# Local development:
#   VITE_SERVER_URL=http://localhost:3001
#
# Hosted server (Render):
#   VITE_SERVER_URL=https://catanagent.onrender.com
VITE_SERVER_URL=http://localhost:3001
